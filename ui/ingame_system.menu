//		"320*240" 0 "400*300" 1 "512*384" 2
		rect 82 50 290 12
      	textalign ITEM_ALIGN_RIGHT
		textfont UI_FONT_BIG
      	textalignx 142
      	textaligny 10
		textscale .22 
		style WINDOW_STYLE_FILLED
		backcolor 1 1 1 .07       
      	forecolor 1 1 1 1
      	visible 0 
		action { uiScript glCustom }
	}
	
