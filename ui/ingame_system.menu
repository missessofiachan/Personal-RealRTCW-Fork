	    textalign 1
		textfont UI_FONT_BIG
	    textalignx 22
	    textaligny 14
	    border 1
	    //bordercolor .1 .1 .1 0
	    forecolor 1 1 1 1
	    visible 0
	}
	
		itemDef {
   		name graphics
