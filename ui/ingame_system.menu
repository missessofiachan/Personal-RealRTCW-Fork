    itemDef {
		name iortcwgraphics	
		group grpsystem
	    text "@SYSTEM_PRESET"
   	    type ITEM_TYPE_MULTI
	    textfont UI_FONT_BIG
	    cvar "ui_glCustom"
	    cvarFloatList { "@SYSTEM_ULTRA" 0 "@SYSTEM_HIGHQUALITY" 1 "@SYSTEM_NORMALQUALITY" 2 "@SYSTEM_LOWQUALITY" 3 "@SYSTEM_CUSTOMQUALITY" 4 }
	    cvarTest		"ui_glCustom"
	    hideCvar		{ "999" }	// 999 is 'recommended'
		rect 82 40 290 12
   	    textalign ITEM_ALIGN_RIGHT
   	    textalignx 142 
   	    textaligny 10
	    textscale .22
	    style WINDOW_STYLE_FILLED
		backcolor 1 1 1 .07     
      	forecolor 1 1 1 1
   	    visible 0 
	    action { uiScript update "ui_glCustom" }
	}

