		background "ui/assets/realrtcw_main.tga"
		visible 1
		decoration
	}
	
	
// Socials

	itemDef {
		name social_border
		group socials
		rect 0 450 320 32 
		style WINDOW_STYLE_FILLED
		border 1
		bordercolor .5 .5 .5 .5
		forecolor 1 1 1 1
		backcolor 0 0 0 .8
		visible 1
		decoration
		
 	    cvarTest "cg_showSocials"
	    showcvar { "1" }
	
	}	
	
	
itemDef
	{
		name socials_close
		style WINDOW_STYLE_SHADER
		rect 310 445 12 12
		background "ui/assets/check_no.tga"
		visible 1
		type 1
		
	    action 
		{ 
		setCvar cg_showSocials "0"; 
		}
		
		cvarTest "cg_showSocials"
	    showcvar { "1" }
	}
	
itemDef 
    {
	name discord_button
	group socials
	type 1
	style WINDOW_STYLE_SHADER
	rect 5 460 89 13
	background "ui/assets/disc_logo.png"
	visible 1
	action { uiScript validate_openURL "https://discord.gg/Tns4CjA" }
	
 	cvarTest "cg_showSocials"
	showcvar { "1" }
	
	mouseEnter { show "discord_button2" } 
	mouseExit { hide "discord_button2" } 	
    }
	
itemDef 
    {
	name discord_button2
	group socials
	type 1
	style WINDOW_STYLE_SHADER
	rect 5 460 89 13
	background "ui/assets/disc_logo2.png"
	visible 0
	action { uiScript validate_openURL "https://discord.gg/Tns4CjA" }
	
 	cvarTest "cg_showSocials"
	showcvar { "1" }
    }
	
