////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////               LOOK CONTROLS MENU          //////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

    itemDef {
	    name lookbutton
	    text "@LOOK"
	    type 1
	    textscale .23
	    group controlbuttons
	    type ITEM_TYPE_BUTTON
	    style WINDOW_STYLE_FILLED
	    rect 250 105 45 20
	    textalign 1
		textfont UI_FONT_BIG
	    textalignx 22
	    textaligny 14
	    border 1
	    bordercolor .1 .1 .1 0
	    forecolor 1 1 1 1
	    visible 0
	    action { hide controls ; show look }
	    mouseEnter { setitemcolor ctr_look backcolor .3 .6 .3 .0 } 
	    mouseExit { setitemcolor ctr_look backcolor .1 .1 .1 0 } 
	}

    itemDef {
	    name look
	    text "@CONTROLS"
 	    type 1
	    textfont UI_FONT_BIG
	    style 0	
	    textstyle 6
	    rect 222.5 -12 64 14 
	    textalign ITEM_ALIGN_CENTER
	    textscale .23		
	    textalignx 2
	    textaligny 12
	    forecolor .9 .9 .9 1
	    visible 0 
	    decoration
    }
	
	    itemDef {
	    name look
		group controls
	    text "@MOUSE_SETTINGS"
	    textscale .25
		decoration
	    style WINDOW_STYLE_FILLED
	    rect 410 125 290 12
	    textalign 1
		textfont UI_FONT_BIG
	    textalignx 22
	    textaligny 14
	    border 1
	    //bordercolor .1 .1 .1 0
	    forecolor 1 1 1 1
	    visible 0
	}

	
		itemDef {
		name look
		group controls
		type ITEM_TYPE_SLIDER
		text "@MOUSE_SENS"
		cvarfloat "sensitivity" 5 1 30
		rect 300 150 290 12
		textalign ITEM_ALIGN_RIGHT
		textfont UI_FONT_BIG
		textalignx 142
		textaligny 10
		textscale .23
		style WINDOW_STYLE_FILLED
		backcolor 1 1 1 .07            
		forecolor 1 1 1 1
		visible 0 
		mouseenter { show slider_message }
		mouseexit { hide slider_message }
    }
	
		itemDef {
		name look
		group controls
		type ITEM_TYPE_YESNO
		text "@MOUSE_INVERT"
		cvar "ui_mousePitch"
		rect 300 165 290 12
		textalign ITEM_ALIGN_RIGHT
		textalignx 142
		textaligny 10
		textscale .23 
		style WINDOW_STYLE_FILLED
		textfont UI_FONT_BIG
		backcolor 1 1 1 .07           
		forecolor 1 1 1 1
		visible 0 
		action { uiScript update ui_mousePitch }
		mouseenter { show yesno_message }
		mouseexit { hide yesno_message }
    }

	itemDef {
		name look
		group controls
		type ITEM_TYPE_YESNO
		text "@MOUSE_SMOOTH"
		cvar "m_filter"
