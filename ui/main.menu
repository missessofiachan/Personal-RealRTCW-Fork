		textalign ITEM_ALIGN_RIGHT
		textfont UI_FONT_BIG
		textalignx 142
		textaligny 10
		textscale .23 
		style WINDOW_STYLE_FILLED
		backcolor 1 1 1 .07           
		forecolor 1 1 1 1
		visible 0 
		mouseenter { show yesno_message }
		mouseexit { hide yesno_message }
    }
	
		itemDef {
		name look
		group controls
		type ITEM_TYPE_MULTI
		text "@MOUSE_ACCEL"
		cvar "cl_mouseAccelStyle"
		cvarFloatList { "@MOUSE_ACCEL_STYLE1" 0 "@MOUSE_ACCEL_STYLE2" 1  }
