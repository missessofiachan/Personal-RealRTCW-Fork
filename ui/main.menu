			//	CLICKABLE LINK	//
		
			itemDef
			{
				group	grpEE
				name	ee
			
				cvarTest 	"g_ee_dlc"
				showCvar	{ "1" }
					
				type ITEM_TYPE_BUTTON
				rect 402 434 236 44
				
				border 			1
				bordercolor 	0 0 0 0
				
				visible 1
				
				style WINDOW_STYLE_SHADER
				background "ui/assets/ee"
				forecolor .8 .8 .8 1
				
				action { exec "game_restart EE" }
				
				mouseEnter { setitemcolor ee forecolor 1 1 1 1 }
				mouseExit { setitemcolor ee forecolor .8 .8 .8 1 }
			}
		
